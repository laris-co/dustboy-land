---
import ConnectWallet from "./ConnectWallet.tsx";
import ThemeToggle from "./ThemeToggle.astro";
const path = Astro.url.pathname;
const links = [
  { href: "/", label: "หน้าแรก" },
  { href: "/blog/", label: "บล็อก" },
  { href: "/books/", label: "หนังสือ" },
  { href: "/members/", label: "สมาชิก" },
  { href: "/about/", label: "เกี่ยวกับ" },
];
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header class="sticky top-0 z-40 border-b border-border bg-bg/95 backdrop-blur-sm">
  <nav aria-label="หลัก" class="mx-auto flex max-w-5xl items-center justify-between gap-3 px-5 py-3">
    <a href="/" class="inline-flex min-h-11 items-center gap-2.5 font-display text-[15px] font-700 tracking-tight">
      <span aria-hidden="true" class="grid h-7 w-7 place-items-center rounded-md border border-border-strong bg-surface text-accent">◇</span>
      <span>DustBoy<span class="text-faint"> · </span><span class="text-accent">PhD</span></span>
    </a>

    <div class="flex items-center gap-1.5 sm:gap-2">
      <div class="hidden items-center gap-1 sm:flex">
        {links.map((l) => (
          <a
            href={l.href}
            aria-current={isActive(l.href) ? "page" : undefined}
            class={`inline-flex min-h-11 items-center rounded-md px-2.5 text-sm underline-offset-4 transition-colors hover:underline ${
              isActive(l.href) ? "text-ink underline decoration-accent" : "text-muted hover:text-ink"
            }`}
          >
            {l.label}
          </a>
        ))}
      </div>

      <ThemeToggle />
      <ConnectWallet client:idle />

      <details class="relative sm:hidden">
        <summary
          aria-label="เมนู"
          class="grid h-11 w-11 cursor-pointer list-none place-items-center rounded-md border border-border-strong bg-surface text-muted [&::-webkit-details-marker]:hidden"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
          </svg>
        </summary>
        <div class="absolute right-0 top-full mt-2 flex w-44 flex-col rounded-lg border border-border-strong bg-surface p-1">
          {links.map((l) => (
            <a
              href={l.href}
              aria-current={isActive(l.href) ? "page" : undefined}
              class={`rounded-md px-3 py-2.5 text-sm transition-colors ${
                isActive(l.href) ? "bg-surface-2 text-ink" : "text-muted hover:bg-surface-2 hover:text-ink"
              }`}
            >
              {l.label}
            </a>
          ))}
        </div>
      </details>
    </div>
  </nav>
</header>
