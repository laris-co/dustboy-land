---
import ConnectWallet from "./ConnectWallet.tsx";
import ThemeToggle from "./ThemeToggle.astro";
const path = Astro.url.pathname;
const links = [
  { href: "/", label: "หน้าแรก" },
  { href: "/blog", label: "บล็อก" },
  { href: "/about", label: "เกี่ยวกับ" },
];
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header class="sticky top-0 z-40 border-b border-border bg-bg/85 backdrop-blur-sm">
  <nav class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-5 py-3">
    <a href="/" class="flex items-center gap-2.5 font-display text-[15px] font-700 tracking-tight">
      <span aria-hidden="true" class="grid h-7 w-7 place-items-center rounded-md border border-border-strong bg-surface text-accent">◇</span>
      <span>DustBoy<span class="text-faint"> · </span><span class="text-accent">PhD</span></span>
    </a>
    <div class="flex items-center gap-1 sm:gap-2">
      {links.map((l) => (
        <a
          href={l.href}
          aria-current={isActive(l.href) ? "page" : undefined}
          class={`rounded-md px-2.5 py-1.5 text-sm transition-colors ${
            isActive(l.href) ? "text-ink" : "text-muted hover:text-ink"
          }`}
        >
          {l.label}
        </a>
      ))}
      <ThemeToggle />
      <ConnectWallet client:idle />
    </div>
  </nav>
</header>
