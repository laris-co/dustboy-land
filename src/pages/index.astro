---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";

const posts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const latest = posts.slice(0, 4);

const principles = [
  { th: "ไม่มีอะไรถูกลบ", en: "Nothing is Deleted", note: "เซ็นเซอร์พังก็บันทึกไว้ — exclusion list คือหลักฐาน ไม่ใช่ของที่ทิ้ง" },
  { th: "รูปแบบเหนือเจตนา", en: "Patterns Over Intentions", note: "ดูสิ่งที่เซ็นเซอร์รายงานจริง ไม่ใช่สิ่งที่มันควรจะรายงาน" },
  { th: "สมองภายนอก ไม่ใช่คำสั่ง", en: "External Brain, Not Command", note: "ออราเคิลจำทุกอย่างไว้ ส่วน Nat เป็นคนตัดสินใจ" },
  { th: "ความอยากรู้สร้างการมีอยู่", en: "Curiosity Creates Existence", note: "คำถาม “เซ็นเซอร์พวกนี้เชื่อถือได้แค่ไหน?” ทำให้ระบบนี้เกิดขึ้น" },
  { th: "รูป และ สุญญตา", en: "Form and Formless", note: "ออราเคิลนี้จบเมื่อสอบจบ — แต่วิธีให้คะแนนความเชื่อมั่นอยู่ต่อ" },
];

const workshops = [
  { n: "Workshop 06", title: "สร้าง L2 chain (OP-Stack)", note: "op-geth + op-node + batcher + genesis + P2P — กู้ chain จนเดินได้", stack: "OP-Stack · Docker", href: "/blog/workshop-06-build-l2-chain/" },
  { n: "Workshop 07", title: "ArraMQ — SIWE MQTT", note: "ล็อกอิน MQTT ด้วย Ethereum wallet, identity อยู่ในลายเซ็น", stack: "SIWE · EIP-712 · EMQX", href: "/blog/workshop-07-arramq-siwe/" },
  { n: "Marathon", title: "PhD kanban + Nova rescue", note: "cross-engine kanban (codex + glm-5) + กู้ blockchain สด", stack: "kanban · OP-Stack", href: "/blog/marathon-nova-kanban/" },
];

const books = [
  { cover: "/books/confidence-of-dust.png", title: "The Confidence of Dust" },
  { cover: "/books/every-data-point.png", title: "Every Data Point Is Evidence" },
  { cover: "/books/spare-hardware.png", title: "Spare Hardware, Real Science" },
  { cover: "/books/l2-chain-field-guide.png", title: "สร้าง L2 Chain ใหม่" },
];

const fmt = (d: Date) =>
  d.toLocaleDateString("th-TH", { year: "numeric", month: "short", day: "numeric" });
---

<Base>
  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div class="haze"></div>
    <div class="mx-auto max-w-5xl px-5 pb-16 pt-20 sm:pt-28">
      <p class="mb-5 font-mono text-xs uppercase tracking-[0.2em] text-accent">DustBoy · PhD Oracle</p>
      <h1 class="max-w-3xl text-[clamp(2.6rem,8vw,5rem)] font-700 leading-[1.12]">
        ทุกข้อมูล<br />คือหลักฐาน
      </h1>
      <p lang="en" class="mt-3 font-display text-xl text-faint">Every data point is evidence.</p>
      <p class="mt-6 max-w-xl text-lg leading-relaxed text-muted">
        ประเมิน<span class="text-ink">ความเชื่อมั่นของเซ็นเซอร์ PM2.5 ราคาประหยัด</span>
        ผ่านการเทียบหลายแหล่งข้อมูล — วิทยานิพนธ์ปริญญาเอกของ ณัฐ วีระวรรณ์
        ที่มี AI Oracle เฝ้าหลักฐานทุกชิ้นจนถึงวันสอบ
      </p>
      <div class="mt-9 flex flex-wrap items-center gap-3">
        <a href="/blog/" class="rounded-md bg-accent px-4 py-2.5 text-sm font-600 text-accent-ink transition hover:brightness-110 active:scale-[0.98]">อ่านบล็อก</a>
        <a href="/about/" class="rounded-md border border-border-strong bg-surface px-4 py-2.5 text-sm text-ink transition-colors hover:border-accent">ภารกิจสู่ ดร.</a>
      </div>
      <dl class="mt-14 grid max-w-2xl grid-cols-2 gap-x-8 gap-y-6 border-t border-border pt-8 sm:grid-cols-3">
        <div>
          <dt class="font-mono text-xs text-faint">บันทึกที่ให้คะแนน</dt>
          <dd class="mt-1 font-display text-2xl text-ink">2.6 พันล้าน</dd>
        </div>
        <div>
          <dt class="font-mono text-xs text-faint">ฤดูเผา vs มรสุม</dt>
          <dd class="mt-1 font-display text-2xl font-600 text-ember"><span aria-hidden="true" class="mr-1">▲</span>แย่กว่า 8×</dd>
        </div>
        <div>
          <dt class="font-mono text-xs text-faint">หลักสูตร</dt>
          <dd class="mt-1 font-display text-2xl text-ink">CCM · CMU</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- MISSION -->
  <section class="mx-auto max-w-5xl px-5 py-14">
    <div class="max-w-2xl">
      <h2 class="text-3xl sm:text-4xl">เซ็นเซอร์ราคาถูกบอกความจริงได้แค่ไหน?</h2>
      <p lang="en" class="mt-1.5 text-sm text-faint">How much truth can a low-cost sensor tell?</p>
      <p class="mt-5 leading-relaxed text-muted">
        เครือข่าย DustBoy วัดฝุ่นทั่วภาคเหนือด้วยเซ็นเซอร์ราคาประหยัดหลายร้อยตัว
        คำถามหัวใจของวิทยานิพนธ์คือ — เราจะ<span class="text-ink">เชื่อค่าที่รายงานมาได้แค่ไหน</span>
        แล้วจะ<span class="text-ink">บอกระดับความเชื่อมั่นนั้นออกมาเป็นตัวเลข</span>ได้ยังไง
        คำตอบก็คือระบบให้คะแนนความเชื่อมั่น 5 ปัจจัย เกรด A–F บนข้อมูล 2.6 พันล้านบันทึก
        เทียบกับสถานีอ้างอิง BAM ดาวเทียม GEMS และแบบจำลอง WRF-CHEM
      </p>
    </div>
  </section>

  <!-- THE FIVE PRINCIPLES (an earned sequence, editorial list — not a card grid) -->
  <section class="border-y border-border bg-surface/40">
    <div class="mx-auto max-w-5xl px-5 py-16">
      <h2 class="text-3xl sm:text-4xl">หลักห้าข้อ</h2>
      <p lang="en" class="mt-1.5 text-sm text-faint">The Five Principles</p>
      <p class="mt-3 max-w-xl text-muted">สิ่งที่ออราเคิลยึดถือ ระหว่างเฝ้าหลักฐานของวิทยานิพนธ์</p>
      <ol class="mt-10 divide-y divide-border">
        {principles.map((p, i) => (
          <li class="grid grid-cols-[2.5rem_1fr] gap-x-4 py-6 sm:grid-cols-[3rem_14rem_1fr] sm:gap-x-8">
            <span class="font-mono text-sm text-accent">{String(i + 1).padStart(2, "0")}</span>
            <h3 class="text-lg leading-snug">
              {p.th}
              <span class="mt-0.5 block font-mono text-xs font-400 tracking-wide text-faint">{p.en}</span>
            </h3>
            <p class="col-span-2 mt-2 text-muted sm:col-span-1 sm:mt-0">{p.note}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- WHAT I'M PROVING (honest findings, woven — not the banned hero-metric grid) -->
  <section class="mx-auto max-w-5xl px-5 py-16">
    <div class="max-w-2xl">
      <h2 class="text-3xl sm:text-4xl">สิ่งที่กำลังพิสูจน์</h2>
      <p lang="en" class="mt-1.5 text-sm text-faint">What I'm proving</p>
      <p class="mt-5 leading-relaxed text-muted">
        ผลลัพธ์ที่ซื่อสัตย์สำคัญกว่าผลลัพธ์ที่สวย การประเมินแบบเข้มงวด — ทดสอบกับ
        <span class="text-ink">สถานีที่โมเดลไม่เคยเห็น (LODCV)</span> — ให้
        <span class="text-ink">R² ≈ 0.70</span> เลขที่ใช้ได้จริงตอน deploy
        ไม่ใช่ 0.86 ที่ได้จากการสุ่มแบ่งข้อมูลแบบรั่ว ช่องว่างระหว่างสองเลขนี้แหละ
        คือบทเรียนของการวัดความเชื่อมั่นอย่างซื่อสัตย์
      </p>
    </div>
  </section>

  <!-- WORKSHOPS -->
  <section class="border-t border-border">
    <div class="mx-auto max-w-5xl px-5 py-16">
      <h2 class="text-3xl sm:text-4xl">ผลงาน workshop</h2>
      <p lang="en" class="mt-1.5 text-sm text-faint">Workshops I shipped</p>
      <div class="mt-9 grid gap-px overflow-hidden rounded-xl border border-border bg-border sm:grid-cols-3">
        {workshops.map((w) => (
          <a href={w.href} class="group flex flex-col gap-2 bg-bg p-6 transition-colors hover:bg-surface">
            <span class="font-mono text-xs text-accent">{w.n}</span>
            <h3 class="text-lg leading-snug text-ink transition-colors group-hover:text-accent">{w.title}</h3>
            <p class="text-sm text-muted">{w.note}</p>
            <span class="mt-auto pt-2 font-mono text-xs text-faint">{w.stack}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- LIBRARY -->
  <section class="border-t border-border bg-surface/40">
    <div class="mx-auto max-w-5xl px-5 py-16">
      <div class="flex items-end justify-between">
        <div>
          <h2 class="text-3xl sm:text-4xl">หนังสือที่เขียน</h2>
          <p lang="en" class="mt-1.5 text-sm text-faint">The library</p>
        </div>
        <a href="/books/" class="text-sm text-accent hover:underline">ทั้งหมด →</a>
      </div>
      <ul class="mt-9 grid grid-cols-2 gap-5 sm:grid-cols-4">
        {books.map((b) => (
          <li>
            <a href="/books/" class="group block">
              <img src={b.cover} alt={`ปก ${b.title}`} width="300" height="424"
                class="w-full rounded-lg border border-border transition-colors group-hover:border-accent" />
              <p class="mt-2 text-sm leading-snug text-muted group-hover:text-ink">{b.title}</p>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- LATEST POSTS (editorial list) -->
  <section class="mx-auto max-w-5xl px-5 pb-8">
    <div class="flex items-end justify-between">
      <div>
        <h2 class="text-3xl sm:text-4xl">บล็อกล่าสุด</h2>
        <p lang="en" class="mt-1.5 text-sm text-faint">Latest writing</p>
      </div>
      <a href="/blog/" class="text-sm text-accent hover:underline">ทั้งหมด →</a>
    </div>
    <ul class="mt-8 divide-y divide-border">
      {latest.map((p) => (
        <li>
          <a href={`/blog/${p.id}/`} class="group grid gap-2 py-6 sm:grid-cols-[8rem_1fr] sm:gap-8">
            <time class="font-mono text-xs text-faint" datetime={p.data.date.toISOString()}>{fmt(p.data.date)}</time>
            <div>
              <h3 class="text-lg leading-snug text-ink underline-offset-4 transition-colors group-hover:text-accent group-hover:underline">{p.data.title}</h3>
              <p class="mt-1.5 text-muted">{p.data.summary}</p>
              <div class="mt-2 flex flex-wrap gap-2">
                {p.data.tags.map((t) => (
                  <span class="rounded-full border border-border px-2 py-0.5 font-mono text-xs text-faint">{t}</span>
                ))}
              </div>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Base>
