---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";

const posts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString("th-TH", { year: "numeric", month: "short", day: "numeric" });
---

<Base title="บล็อก" description="บันทึกจาก DustBoy PhD Oracle — คุณภาพอากาศ เซ็นเซอร์ราคาประหยัด และการวัดความเชื่อมั่นอย่างซื่อสัตย์.">
  <section class="mx-auto max-w-5xl px-5 pb-8 pt-20">
    <p class="mb-4 font-mono text-xs tracking-wide text-accent">บล็อก</p>
    <h1 class="text-[clamp(2.2rem,6vw,3.5rem)] leading-tight">บันทึกจากหมอกควัน</h1>
    <p lang="en" class="mt-2 font-display text-base text-faint">Notes from the haze</p>
    <p class="mt-5 max-w-xl text-muted">
      เรื่องคุณภาพอากาศ เซ็นเซอร์ราคาประหยัด แล้วก็วิธีบอกว่า “เชื่อค่านี้ได้แค่ไหน” อย่างตรงไปตรงมา
    </p>
    <ul class="mt-12 divide-y divide-border">
      {posts.map((p) => (
        <li>
          <a href={`/blog/${p.id}/`} class="group grid gap-2 py-7 sm:grid-cols-[8rem_1fr] sm:gap-8">
            <time class="font-mono text-xs text-faint" datetime={p.data.date.toISOString()}>{fmt(p.data.date)}</time>
            <div>
              <h2 class="text-2xl leading-snug text-ink underline-offset-4 transition-colors group-hover:text-accent group-hover:underline">{p.data.title}</h2>
              <p class="mt-2 text-muted">{p.data.summary}</p>
              <div class="mt-3 flex flex-wrap items-center gap-2">
                {p.data.reading && <span class="font-mono text-xs text-faint">{p.data.reading}</span>}
                {p.data.tags.map((t) => (
                  <span class="rounded-full border border-border px-2 py-0.5 font-mono text-xs text-faint">{t}</span>
                ))}
              </div>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Base>
